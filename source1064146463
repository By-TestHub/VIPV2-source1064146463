Tab3:Button({
    Title = "วาร์ปไป เพื่อกระเด็นผู้เล่นที่เลือก",
    Callback = function()
        local targetName = MyPlayerDropdown.Value 
        
        if targetName and targetName ~= "" and targetName ~= "--" then
            local target = Players:FindFirstChild(targetName)
        
            if not target then
                for _, p in pairs(Players:GetPlayers()) do
                    if p.DisplayName == targetName or p.Name == targetName then
                        target = p
                        break
                    end
                end
            end
            
            local Char = Player.Character
            local RootPart = Char and Char:FindFirstChild("HumanoidRootPart")
            local Hum = Char and Char:FindFirstChildOfClass("Humanoid")
            
            if target and target.Character and RootPart then
                local oldPos = RootPart.CFrame
                flingActive = true 
                SkidFling(target) 
                flingActive = false
                RootPart.Anchored = true 
                RootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                RootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                RootPart.CFrame = oldPos 
                task.wait(0.05)
                RootPart.Anchored = false 
                if Hum then Hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
            else
                Message("ไม่สำเร็จ", "ไม่พบผู้เล่นคนนี้ในเซิร์ฟเวอร์", 3)
            end
        else
            Message("ไม่สำเร็จ", "กรุณาเลือกชื่อผู้เล่นก่อน", 3)
        end
